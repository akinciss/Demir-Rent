rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cars collection: publicly readable, only admins can write/update/delete
    match /cars/{carId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null &&
        exists(/databases/$(database)/documents/roles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true;
    }

    // Rentals collection: users can create/read their own, admins can read/update/delete any
    match /rentals/{rentalId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (exists(/databases/$(database)/documents/roles/$(request.auth.uid)) && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true)
      );

      allow update, delete: if request.auth != null &&
        exists(/databases/$(database)/documents/roles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true;
    }

    // Roles collection: only admins can modify/read roles (protect against privilege escalation)
    match /roles/{roleId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/roles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true;
    }

    // CarSlots collection: publicly readable, writes only via Admin SDK (server-side)
    match /carSlots/{slotId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
