rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Cars collection ───────────────────────────────────────────
    // Publicly readable. Client-side writes are strictly CLOSED.
    // Admin operations are performed exclusively via API/Admin SDK.
    match /cars/{carId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Rentals collection ────────────────────────────────────────
    // - create/update/delete: CLOSED on client side.
    // - read: Users can read their own rentals; admins can read all.
    match /rentals/{rentalId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow write: if false;
    }

    // ── CarSlots collection ───────────────────────────────────────
    // Publicly readable. Client-side writes are strictly CLOSED.
    match /carSlots/{slotId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Roles collection ──────────────────────────────────────────
    // Only admins can read roles. Client-side writes are strictly CLOSED.
    match /roles/{roleId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Users collection ──────────────────────────────────────────
    // Users can only read and update their own profile. Client-side creates/deletes are CLOSED.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId);
      allow create, delete: if false;
    }
  }
}
